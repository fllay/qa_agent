QA_AGENT_DATA_DIR=data
QA_AGENT_DATABASE_PATH=data/qa_agent.sqlite
GRAPHIFY_BIN=auto
GRAPHIFY_TIMEOUT_SECONDS=900
GITHUB_TOKEN=
GITHUB_MAX_PAGES=10
GITHUB_PER_PAGE=100
QA_AGENT_LLM_PROVIDER=local
QA_AGENT_LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
QA_AGENT_LOCAL_LLM_API_KEY=local
QA_AGENT_LOCAL_LLM_MODEL=llama3.1:8b

# Set QA_AGENT_LLM_PROVIDER=openrouter to use OpenRouter.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAIN_MODEL=openrouter/auto
OPENROUTER_RESERVE_MODEL_1=openai/gpt-4o-mini
OPENROUTER_RESERVE_MODEL_2=google/gemini-flash-1.5

# Optional: Graphify semantic extraction API keys.
# If none are set, QA Agent falls back to Graphify's code-only update mode.
GEMINI_API_KEY=
GOOGLE_API_KEY=
MOONSHOT_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
